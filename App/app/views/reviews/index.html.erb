<% content_for :title, "Reviews | EventHub" %>

<section class="py-5 bg-light">
  <div class="container">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
      <div>
        <h1 class="fw-bold mb-1">Reviews</h1>
        <p class="text-muted mb-0">Read feedback written by attendees after completed events.</p>
      </div>

      <%= link_to root_path, class: "btn btn-outline-primary" do %>
        <i class="bi bi-house me-1"></i>
        Back to Home
      <% end %>
    </div>

    <div class="row g-4">
      <% @reviews.each do |review| %>
        <div class="col-md-6 col-xl-4">
          <div class="card h-100 border-0 shadow-sm rounded-4">
            <div class="card-body p-4 d-flex flex-column">
              <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                <span class="badge text-bg-warning">
                  <i class="bi bi-star-fill me-1"></i>
                  <%= review.rating %>/5
                </span>

                <span class="badge text-bg-secondary">
                  <%= review.event.category.name %>
                </span>
              </div>

              <h2 class="h5 fw-bold mb-2">
                <%= link_to review.event.title, event_path(review.event), class: "text-decoration-none text-dark" %>
              </h2>

              <p class="text-muted small mb-3">
                Reviewed by
                <%= link_to review.user.full_name, user_path(review.user), class: "fw-semibold text-decoration-none" %>
              </p>

              <p class="text-muted mb-4">
                <%= truncate(review.comment, length: 130) %>
              </p>

              <div class="mt-auto">
                <%= link_to "View review", review_path(review), class: "btn btn-sm btn-primary" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <% if @reviews.empty? %>
      <div class="alert alert-info mt-4 mb-0">
        No reviews have been created yet.
      </div>
    <% end %>
  </div>
</section>