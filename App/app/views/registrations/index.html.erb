<% content_for :title, "Registrations | EventHub" %>

<section class="py-5 bg-light">
  <div class="container">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
      <div>
        <h1 class="fw-bold mb-1">Registrations</h1>
        <p class="text-muted mb-0">Review confirmed, waitlisted, and cancelled event registrations.</p>
      </div>

      <%= link_to root_path, class: "btn btn-outline-primary" do %>
        <i class="bi bi-house me-1"></i>
        Back to Home
      <% end %>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body p-0">
        <% if @registrations.any? %>
          <div class="table-responsive">
            <table class="table align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th class="ps-4">User</th>
                  <th>Event</th>
                  <th>Status</th>
                  <th>Registered at</th>
                  <th>Waitlist</th>
                  <th class="pe-4"></th>
                </tr>
              </thead>
              <tbody>
                <% @registrations.each do |registration| %>
                  <tr>
                    <td class="ps-4">
                      <%= link_to registration.user.full_name, user_path(registration.user), class: "fw-semibold text-decoration-none" %>
                    </td>
                    <td>
                      <%= link_to registration.event.title, event_path(registration.event), class: "text-decoration-none" %>
                    </td>
                    <td>
                      <span class="badge text-bg-secondary text-capitalize">
                        <%= registration.status %>
                      </span>
                    </td>
                    <td><%= registration.registered_at.strftime("%B %d, %Y %H:%M") %></td>
                    <td><%= registration.waitlist_position || "—" %></td>
                    <td class="text-end pe-4">
                      <%= link_to "View", registration_path(registration), class: "btn btn-sm btn-primary" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="p-4">
            <p class="text-muted mb-0">No registrations have been created yet.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>