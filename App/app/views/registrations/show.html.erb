<% content_for :title, "Registration ##{@registration.id} | EventHub" %>

<section class="py-5 bg-light">
  <div class="container">
    <div class="mb-4">
      <%= link_to registrations_path, class: "btn btn-outline-primary btn-sm" do %>
        <i class="bi bi-arrow-left me-1"></i>
        Back to Registrations
      <% end %>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body p-4 p-lg-5">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
          <div>
            <span class="badge text-bg-secondary text-capitalize mb-3">
              <%= @registration.status %>
            </span>
            <h1 class="fw-bold mb-2">Registration #<%= @registration.id %></h1>
            <p class="text-muted mb-0">Detailed read-only registration information.</p>
          </div>
        </div>

        <div class="row g-4">
          <div class="col-md-6">
            <div class="p-3 bg-light rounded-3 h-100">
              <p class="text-muted small mb-1">User</p>
              <p class="fw-semibold mb-0">
                <%= link_to @registration.user.full_name, user_path(@registration.user), class: "text-decoration-none" %>
              </p>
            </div>
          </div>

          <div class="col-md-6">
            <div class="p-3 bg-light rounded-3 h-100">
              <p class="text-muted small mb-1">Event</p>
              <p class="fw-semibold mb-0">
                <%= link_to @registration.event.title, event_path(@registration.event), class: "text-decoration-none" %>
              </p>
            </div>
          </div>

          <div class="col-md-6">
            <div class="p-3 bg-light rounded-3 h-100">
              <p class="text-muted small mb-1">Registered at</p>
              <p class="fw-semibold mb-0">
                <i class="bi bi-calendar-event me-2 text-primary"></i>
                <%= @registration.registered_at.strftime("%B %d, %Y at %H:%M") %>
              </p>
            </div>
          </div>

          <div class="col-md-6">
            <div class="p-3 bg-light rounded-3 h-100">
              <p class="text-muted small mb-1">Cancelled at</p>
              <p class="fw-semibold mb-0">
                <% if @registration.cancelled_at.present? %>
                  <%= @registration.cancelled_at.strftime("%B %d, %Y at %H:%M") %>
                <% else %>
                  —
                <% end %>
              </p>
            </div>
          </div>

          <div class="col-md-6">
            <div class="p-3 bg-light rounded-3 h-100">
              <p class="text-muted small mb-1">Waitlist position</p>
              <p class="fw-semibold mb-0">
                <%= @registration.waitlist_position || "—" %>
              </p>
            </div>
          </div>

          <div class="col-md-6">
            <div class="p-3 bg-light rounded-3 h-100">
              <p class="text-muted small mb-1">Event venue</p>
              <p class="fw-semibold mb-0">
                <%= link_to @registration.event.venue.name, venue_path(@registration.event.venue), class: "text-decoration-none" %>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>