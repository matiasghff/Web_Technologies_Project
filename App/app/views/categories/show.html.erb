<% content_for :title, "#{@category.name} | EventHub" %>

<section class="py-5 bg-light">
  <div class="container">
    <div class="mb-4">
      <%= link_to categories_path, class: "btn btn-outline-primary btn-sm" do %>
        <i class="bi bi-arrow-left me-1"></i>
        Back to Categories
      <% end %>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-4">
      <div class="card-body p-4 p-lg-5">
        <span class="badge text-bg-primary mb-3">Category</span>
        <h1 class="fw-bold mb-3"><%= @category.name %></h1>

        <p class="text-muted mb-0">
          <%= @category.description %>
        </p>
      </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
      <h2 class="h4 fw-bold mb-0">Events in this category</h2>
      <span class="badge text-bg-secondary">
        <%= pluralize(@category.events.size, "event") %>
      </span>
    </div>

    <% if @category.events.any? %>
      <div class="row g-4">
        <% @category.events.order(starts_at: :asc).each do |event| %>
          <div class="col-md-6 col-xl-4">
            <div class="card h-100 border-0 shadow-sm rounded-4">
              <div class="card-body p-4 d-flex flex-column">
                <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
                  <span class="badge text-bg-secondary text-capitalize">
                    <%= event.status %>
                  </span>
                </div>

                <h3 class="h5 fw-bold mb-2">
                  <%= link_to event.title, event_path(event), class: "text-decoration-none text-dark" %>
                </h3>

                <p class="text-muted small mb-3">
                  Organized by <strong><%= event.organizer.full_name %></strong>
                </p>

                <div class="small text-muted mb-3">
                  <p class="mb-2">
                    <i class="bi bi-calendar-event me-2 text-primary"></i>
                    <%= event.starts_at.strftime("%B %d, %Y at %H:%M") %>
                  </p>

                  <p class="mb-0">
                    <i class="bi bi-geo-alt me-2 text-primary"></i>
                    <%= event.venue.name %>
                  </p>
                </div>

                <div class="mt-auto">
                  <%= link_to "View event", event_path(event), class: "btn btn-sm btn-primary" %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="alert alert-info mb-0">
        There are no events in this category yet.
      </div>
    <% end %>
  </div>
</section>