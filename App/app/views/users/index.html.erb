<% content_for :title, "Users | EventHub" %>

<section class="py-5 bg-light">
  <div class="container">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
      <div>
        <h1 class="fw-bold mb-1">Users</h1>
        <p class="text-muted mb-0">Explore sample users, organizers, attendees, and admins.</p>
      </div>

      <%= link_to root_path, class: "btn btn-outline-primary" do %>
        <i class="bi bi-house me-1"></i>
        Back to Home
      <% end %>
    </div>

    <div class="row g-4">
      <% @users.each do |user| %>
        <div class="col-md-6 col-xl-4">
          <div class="card h-100 border-0 shadow-sm rounded-4">
            <div class="card-body p-4 d-flex flex-column">
              <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                <h2 class="h5 fw-bold mb-0">
                  <%= link_to user.full_name, user_path(user), class: "text-decoration-none text-dark" %>
                </h2>

                <span class="badge text-bg-secondary text-capitalize">
                  <%= user.role %>
                </span>
              </div>

              <p class="text-muted mb-3">
                <i class="bi bi-envelope me-2 text-primary"></i>
                <%= user.email %>
              </p>

              <div class="small text-muted mb-4">
                <p class="mb-2">
                  <i class="bi bi-calendar-plus me-2 text-primary"></i>
                  <%= pluralize(user.organized_events.size, "organized event") %>
                </p>

                <p class="mb-2">
                  <i class="bi bi-ticket-perforated me-2 text-primary"></i>
                  <%= pluralize(user.registrations.size, "registration") %>
                </p>

                <p class="mb-0">
                  <i class="bi bi-star me-2 text-primary"></i>
                  <%= pluralize(user.reviews.size, "review") %>
                </p>
              </div>

              <div class="mt-auto">
                <%= link_to "View user", user_path(user), class: "btn btn-sm btn-primary" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <% if @users.empty? %>
      <div class="alert alert-info mt-4 mb-0">
        No users have been created yet.
      </div>
    <% end %>
  </div>
</section>