<% content_for :title, "#{@user.full_name} | EventHub" %>

<section class="py-5 bg-light">
  <div class="container">
    <div class="mb-4">
      <%= link_to users_path, class: "btn btn-outline-primary btn-sm" do %>
        <i class="bi bi-arrow-left me-1"></i>
        Back to Users
      <% end %>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-4">
      <div class="card-body p-4 p-lg-5">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
          <div>
            <span class="badge text-bg-secondary text-capitalize mb-3"><%= @user.role %></span>
            <h1 class="fw-bold mb-2"><%= @user.full_name %></h1>
            <p class="text-muted mb-0">
              <i class="bi bi-envelope me-2 text-primary"></i>
              <%= @user.email %>
            </p>
          </div>

          <div class="text-lg-end">
            <p class="mb-1 text-muted small">User ID</p>
            <p class="fw-semibold mb-0">#<%= @user.id %></p>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 h-100">
          <div class="card-body p-4">
            <h2 class="h5 fw-bold mb-3">Organized events</h2>

            <% if @user.organized_events.any? %>
              <div class="list-group list-group-flush">
                <% @user.organized_events.order(starts_at: :asc).each do |event| %>
                  <%= link_to event_path(event), class: "list-group-item list-group-item-action px-0" do %>
                    <div class="fw-semibold"><%= event.title %></div>
                    <div class="small text-muted">
                      <%= event.status.capitalize %> · <%= event.category.name %>
                    </div>
                  <% end %>
                <% end %>
              </div>
            <% else %>
              <p class="text-muted mb-0">This user has not organized events yet.</p>
            <% end %>
          </div>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 h-100">
          <div class="card-body p-4">
            <h2 class="h5 fw-bold mb-3">Registrations</h2>

            <% if @user.registrations.any? %>
              <div class="list-group list-group-flush">
                <% @user.registrations.includes(:event).order(registered_at: :desc).each do |registration| %>
                  <%= link_to registration_path(registration), class: "list-group-item list-group-item-action px-0" do %>
                    <div class="fw-semibold"><%= registration.event.title %></div>
                    <div class="small text-muted text-capitalize">
                      <%= registration.status %>
                      <% if registration.waitlist_position.present? %>
                        · Position <%= registration.waitlist_position %>
                      <% end %>
                    </div>
                  <% end %>
                <% end %>
              </div>
            <% else %>
              <p class="text-muted mb-0">This user has no registrations yet.</p>
            <% end %>
          </div>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 h-100">
          <div class="card-body p-4">
            <h2 class="h5 fw-bold mb-3">Reviews</h2>

            <% if @user.reviews.any? %>
              <div class="list-group list-group-flush">
                <% @user.reviews.includes(:event).order(created_at: :desc).each do |review| %>
                  <%= link_to review_path(review), class: "list-group-item list-group-item-action px-0" do %>
                    <div class="fw-semibold"><%= review.event.title %></div>
                    <div class="small text-muted">
                      <i class="bi bi-star-fill text-warning me-1"></i>
                      <%= review.rating %>/5
                    </div>
                  <% end %>
                <% end %>
              </div>
            <% else %>
              <p class="text-muted mb-0">This user has not written reviews yet.</p>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>