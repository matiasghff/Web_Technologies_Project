<% content_for :title, "#{@event.title} | EventHub" %>

<section class="py-5 bg-light">
  <div class="container">
    <div class="mb-4">
      <%= link_to events_path, class: "btn btn-outline-primary btn-sm" do %>
        <i class="bi bi-arrow-left me-1"></i>
        Back to Events
      <% end %>
    </div>

    <div class="row g-4">
      <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 mb-4">
          <div class="card-body p-4 p-lg-5">
            <div class="d-flex flex-wrap gap-2 mb-3">
              <span class="badge text-bg-primary"><%= @event.category.name %></span>
              <span class="badge text-bg-secondary text-capitalize"><%= @event.status %></span>
            </div>

            <h1 class="fw-bold mb-3"><%= @event.title %></h1>

            <p class="text-muted mb-4">
              Organized by
              <%= link_to @event.organizer.full_name, user_path(@event.organizer), class: "fw-semibold" %>
            </p>

            <div class="row g-3 mb-4">
              <div class="col-md-6">
                <div class="p-3 bg-light rounded-3 h-100">
                  <p class="text-muted small mb-1">Starts at</p>
                  <p class="fw-semibold mb-0">
                    <i class="bi bi-calendar-event me-2 text-primary"></i>
                    <%= @event.starts_at.strftime("%B %d, %Y at %H:%M") %>
                  </p>
                </div>
              </div>

              <div class="col-md-6">
                <div class="p-3 bg-light rounded-3 h-100">
                  <p class="text-muted small mb-1">Ends at</p>
                  <p class="fw-semibold mb-0">
                    <i class="bi bi-calendar-check me-2 text-primary"></i>
                    <%= @event.ends_at.strftime("%B %d, %Y at %H:%M") %>
                  </p>
                </div>
              </div>
            </div>

            <h2 class="h5 fw-bold mb-3">Event overview</h2>

            <p class="text-muted mb-0">
              This read-only page displays the event data loaded from the database.
              In later assignments, this section can be replaced by the rich text
              event description created by the organizer.
            </p>
          </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 mb-4">
          <div class="card-body p-4">
            <h2 class="h5 fw-bold mb-3">Registrations</h2>

            <% if @event.registrations.any? %>
              <div class="table-responsive">
                <table class="table align-middle">
                  <thead>
                    <tr>
                      <th>User</th>
                      <th>Status</th>
                      <th>Registered at</th>
                      <th>Waitlist position</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% @event.registrations.order(:status, :waitlist_position, :registered_at).each do |registration| %>
                      <tr>
                        <td>
                          <%= link_to registration.user.full_name, user_path(registration.user), class: "fw-semibold text-decoration-none" %>
                        </td>
                        <td>
                          <span class="badge text-bg-secondary text-capitalize">
                            <%= registration.status %>
                          </span>
                        </td>
                        <td>
                          <%= registration.registered_at.strftime("%B %d, %Y %H:%M") %>
                        </td>
                        <td>
                          <%= registration.waitlist_position || "—" %>
                        </td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            <% else %>
              <p class="text-muted mb-0">There are no registrations for this event yet.</p>
            <% end %>
          </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4">
          <div class="card-body p-4">
            <h2 class="h5 fw-bold mb-3">Reviews</h2>

            <% if @event.reviews.any? %>
              <div class="row g-3">
                <% @event.reviews.each do |review| %>
                  <div class="col-12">
                    <div class="p-3 bg-light rounded-3">
                      <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                        <p class="fw-semibold mb-0">
                          <%= link_to review.user.full_name, user_path(review.user), class: "text-decoration-none" %>
                        </p>

                        <span class="badge text-bg-warning">
                          <i class="bi bi-star-fill me-1"></i>
                          <%= review.rating %>/5
                        </span>
                      </div>

                      <p class="text-muted mb-0"><%= review.comment %></p>
                    </div>
                  </div>
                <% end %>
              </div>
            <% else %>
              <p class="text-muted mb-0">There are no reviews for this event yet.</p>
            <% end %>
          </div>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 mb-4">
          <div class="card-body p-4">
            <h2 class="h5 fw-bold mb-3">Capacity</h2>

            <div class="d-flex justify-content-between mb-2">
              <span class="text-muted">Confirmed attendees</span>
              <strong><%= @event.confirmed_attendees_count %></strong>
            </div>

            <div class="d-flex justify-content-between mb-2">
              <span class="text-muted">Maximum attendees</span>
              <strong><%= @event.max_attendees %></strong>
            </div>

            <div class="d-flex justify-content-between mb-2">
              <span class="text-muted">Available spots</span>
              <strong><%= @event.available_spots %></strong>
            </div>

            <div class="d-flex justify-content-between">
              <span class="text-muted">Waiting list</span>
              <strong><%= @event.waitlisted_registrations.count %></strong>
            </div>
          </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 mb-4">
          <div class="card-body p-4">
            <h2 class="h5 fw-bold mb-3">Venue</h2>

            <p class="fw-semibold mb-1">
              <%= link_to @event.venue.name, venue_path(@event.venue), class: "text-decoration-none" %>
            </p>

            <p class="text-muted mb-0">
              <i class="bi bi-geo-alt me-2 text-primary"></i>
              <%= @event.venue.full_location %>
            </p>
          </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4">
          <div class="card-body p-4">
            <h2 class="h5 fw-bold mb-3">Rating</h2>

            <% if @event.average_rating.present? %>
              <p class="display-6 fw-bold mb-0">
                <i class="bi bi-star-fill text-warning me-2"></i>
                <%= @event.average_rating %>
              </p>
              <p class="text-muted mb-0">Average rating</p>
            <% else %>
              <p class="text-muted mb-0">No reviews yet.</p>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>