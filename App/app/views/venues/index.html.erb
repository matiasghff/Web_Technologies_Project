<% content_for :title, "Venues | EventHub" %>

<section class="py-5 bg-light">
  <div class="container">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
      <div>
        <h1 class="fw-bold mb-1">Venues</h1>
        <p class="text-muted mb-0">
          Explore the campus locations available for EventHub activities.
        </p>
      </div>

      <%= link_to root_path, class: "btn btn-outline-primary" do %>
        <i class="bi bi-house me-1"></i>
        Back to Home
      <% end %>
    </div>

    <div class="row g-4">
      <% @venues.each do |venue| %>
        <div class="col-md-6 col-xl-4">
          <div class="card h-100 border-0 shadow-sm rounded-4">
            <div class="card-body p-4 d-flex flex-column">
              <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                <h2 class="h5 fw-bold mb-0">
                  <%= link_to venue.name, venue_path(venue), class: "text-decoration-none text-dark" %>
                </h2>

                <span class="badge text-bg-primary">
                  <%= pluralize(venue.events.size, "event") %>
                </span>
              </div>

              <div class="text-muted mb-4">
                <p class="mb-2">
                  <i class="bi bi-building me-2 text-primary"></i>
                  <%= venue.building %>
                </p>

                <p class="mb-2">
                  <i class="bi bi-door-open me-2 text-primary"></i>
                  Room <%= venue.room %>
                </p>

                <p class="mb-0">
                  <i class="bi bi-people me-2 text-primary"></i>
                  Capacity: <%= venue.max_capacity %>
                </p>
              </div>

              <div class="mt-auto">
                <%= link_to "View venue", venue_path(venue), class: "btn btn-sm btn-primary" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <% if @venues.empty? %>
      <div class="alert alert-info mt-4 mb-0">
        No venues have been created yet.
      </div>
    <% end %>
  </div>
</section>