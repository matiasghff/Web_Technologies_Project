<% content_for :title, "#{@venue.name} | EventHub" %>

<section class="py-5 bg-light">
  <div class="container">
    <div class="mb-4">
      <%= link_to venues_path, class: "btn btn-outline-primary btn-sm" do %>
        <i class="bi bi-arrow-left me-1"></i>
        Back to Venues
      <% end %>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-4">
      <div class="card-body p-4 p-lg-5">
        <span class="badge text-bg-primary mb-3">Venue</span>
        <h1 class="fw-bold mb-3"><%= @venue.name %></h1>

        <div class="row g-3">
          <div class="col-md-6 col-xl-3">
            <div class="p-3 bg-light rounded-3 h-100">
              <p class="text-muted small mb-1">Building</p>
              <p class="fw-semibold mb-0">
                <i class="bi bi-building me-2 text-primary"></i>
                <%= @venue.building %>
              </p>
            </div>
          </div>

          <div class="col-md-6 col-xl-3">
            <div class="p-3 bg-light rounded-3 h-100">
              <p class="text-muted small mb-1">Room</p>
              <p class="fw-semibold mb-0">
                <i class="bi bi-door-open me-2 text-primary"></i>
                <%= @venue.room %>
              </p>
            </div>
          </div>

          <div class="col-md-6 col-xl-3">
            <div class="p-3 bg-light rounded-3 h-100">
              <p class="text-muted small mb-1">Capacity</p>
              <p class="fw-semibold mb-0">
                <i class="bi bi-people me-2 text-primary"></i>
                <%= @venue.max_capacity %> people
              </p>
            </div>
          </div>

          <div class="col-md-6 col-xl-3">
            <div class="p-3 bg-light rounded-3 h-100">
              <p class="text-muted small mb-1">Address</p>
              <p class="fw-semibold mb-0">
                <i class="bi bi-geo-alt me-2 text-primary"></i>
                <%= @venue.address %>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
      <h2 class="h4 fw-bold mb-0">Events at this venue</h2>
      <span class="badge text-bg-secondary">
        <%= pluralize(@venue.events.size, "event") %>
      </span>
    </div>

    <% if @venue.events.any? %>
      <div class="row g-4">
        <% @venue.events.order(starts_at: :asc).each do |event| %>
          <div class="col-md-6 col-xl-4">
            <div class="card h-100 border-0 shadow-sm rounded-4">
              <div class="card-body p-4 d-flex flex-column">
                <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
                  <span class="badge text-bg-primary">
                    <%= event.category.name %>
                  </span>

                  <span class="badge text-bg-secondary text-capitalize">
                    <%= event.status %>
                  </span>
                </div>

                <h3 class="h5 fw-bold mb-2">
                  <%= link_to event.title, event_path(event), class: "text-decoration-none text-dark" %>
                </h3>

                <p class="text-muted small mb-3">
                  Organized by <strong><%= event.organizer.full_name %></strong>
                </p>

                <div class="small text-muted mb-3">
                  <p class="mb-2">
                    <i class="bi bi-calendar-event me-2 text-primary"></i>
                    <%= event.starts_at.strftime("%B %d, %Y at %H:%M") %>
                  </p>

                  <p class="mb-0">
                    <i class="bi bi-people me-2 text-primary"></i>
                    <%= event.confirmed_attendees_count %> confirmed /
                    <%= event.max_attendees %> max
                  </p>
                </div>

                <div class="mt-auto">
                  <%= link_to "View event", event_path(event), class: "btn btn-sm btn-primary" %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="alert alert-info mb-0">
        There are no events assigned to this venue yet.
      </div>
    <% end %>
  </div>
</section>